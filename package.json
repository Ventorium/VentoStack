{
  "name": "ventostack-framework",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ventorium/VentoStack.git"
  },
  "workspaces": ["packages/framework/*", "packages/platform/*", "apps/*", "apps/admin/*"],
  "scripts": {
    "dev": "bun --hot apps/example/src/main.ts",
    "dev:admin": "bun run --cwd apps/admin/api dev",
    "dev:admin:web": "bun run --cwd apps/admin/web dev",
    "dev:doc": "bun run --cwd apps/docs dev",
    "build": "bun run packages/framework/cli/src/build.ts",
    "build:doc": "bun run --cwd apps/docs build",
    "changeset": "changeset",
    "release": "changeset publish",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.31.0",
    "bun-types": "latest",
    "typescript": "^5.8"
  },
  "overrides": {
    "vite": "^7.3.2"
  }
}
