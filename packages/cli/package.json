{
  "name": "@ventostack/cli",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ventorium/VentoStack.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "ventostack": "src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "dependencies": {
    "@ventostack/core": "workspace:*",
    "@ventostack/database": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
