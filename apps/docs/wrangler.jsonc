{
	"name": "vento-stack-docs",
	"compatibility_date": "2026-04-21",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"ai": {
		"binding": "AI"
	},
	"vars": {
		"WORKER_AI_MODEL": "@cf/zai-org/glm-4.7-flash"
	},
	"observability": {
		"enabled": true
	}
}
