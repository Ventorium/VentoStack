{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "erasableSyntaxOnly": true,
    "types": ["bun-types"],
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@ventostack/core": ["../../../packages/framework/core/src/index.ts"],
      "@ventostack/core/*": ["../../../packages/framework/core/src/*"],
      "@ventostack/database": ["../../../packages/framework/database/src/index.ts"],
      "@ventostack/database/*": ["../../../packages/framework/database/src/*"],
      "@ventostack/cache": ["../../../packages/framework/cache/src/index.ts"],
      "@ventostack/cache/*": ["../../../packages/framework/cache/src/*"],
      "@ventostack/events": ["../../../packages/framework/events/src/index.ts"],
      "@ventostack/events/*": ["../../../packages/framework/events/src/*"],
      "@ventostack/observability": ["../../../packages/framework/observability/src/index.ts"],
      "@ventostack/observability/*": ["../../../packages/framework/observability/src/*"],
      "@ventostack/openapi": ["../../../packages/framework/openapi/src/index.ts"],
      "@ventostack/openapi/*": ["../../../packages/framework/openapi/src/*"],
      "@ventostack/auth": ["../../../packages/platform/auth/src/index.ts"],
      "@ventostack/auth/*": ["../../../packages/platform/auth/src/*"],
      "@ventostack/boot": ["../../../packages/platform/boot/src/index.ts"],
      "@ventostack/boot/*": ["../../../packages/platform/boot/src/*"],
      "@ventostack/gen": ["../../../packages/platform/gen/src/index.ts"],
      "@ventostack/gen/*": ["../../../packages/platform/gen/src/*"],
      "@ventostack/i18n": ["../../../packages/platform/i18n/src/index.ts"],
      "@ventostack/i18n/*": ["../../../packages/platform/i18n/src/*"],
      "@ventostack/monitor": ["../../../packages/platform/monitor/src/index.ts"],
      "@ventostack/monitor/*": ["../../../packages/platform/monitor/src/*"],
      "@ventostack/notification": ["../../../packages/platform/notification/src/index.ts"],
      "@ventostack/notification/*": ["../../../packages/platform/notification/src/*"],
      "@ventostack/oss": ["../../../packages/platform/oss/src/index.ts"],
      "@ventostack/oss/*": ["../../../packages/platform/oss/src/*"],
      "@ventostack/scheduler": ["../../../packages/platform/scheduler/src/index.ts"],
      "@ventostack/scheduler/*": ["../../../packages/platform/scheduler/src/*"],
      "@ventostack/system": ["../../../packages/platform/system/src/index.ts"],
      "@ventostack/system/*": ["../../../packages/platform/system/src/*"],
      "@ventostack/workflow": ["../../../packages/platform/workflow/src/index.ts"],
      "@ventostack/workflow/*": ["../../../packages/platform/workflow/src/*"]
    }
  },
  "include": ["src"]
}
