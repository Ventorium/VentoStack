{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": ["ESNext"],
    "types": ["bun-types"],
    "paths": {
      "@ventostack/core": ["./packages/core/src/index.ts"],
      "@ventostack/core/*": ["./packages/core/src/*"],
      "@ventostack/database": ["./packages/database/src/index.ts"],
      "@ventostack/database/*": ["./packages/database/src/*"],
      "@ventostack/cache": ["./packages/cache/src/index.ts"],
      "@ventostack/cache/*": ["./packages/cache/src/*"],
      "@ventostack/auth": ["./packages/auth/src/index.ts"],
      "@ventostack/auth/*": ["./packages/auth/src/*"],
      "@ventostack/events": ["./packages/events/src/index.ts"],
      "@ventostack/events/*": ["./packages/events/src/*"],
      "@ventostack/observability": ["./packages/observability/src/index.ts"],
      "@ventostack/observability/*": ["./packages/observability/src/*"],
      "@ventostack/testing": ["./packages/testing/src/index.ts"],
      "@ventostack/testing/*": ["./packages/testing/src/*"],
      "@ventostack/cli": ["./packages/cli/src/index.ts"],
      "@ventostack/cli/*": ["./packages/cli/src/*"],
      "@ventostack/openapi": ["./packages/openapi/src/index.ts"],
      "@ventostack/openapi/*": ["./packages/openapi/src/*"],
      "@ventostack/ai": ["./packages/ai/src/index.ts"],
      "@ventostack/ai/*": ["./packages/ai/src/*"],
      "@ventostack/webhook": ["./packages/webhook/src/index.ts"],
      "@ventostack/webhook/*": ["./packages/webhook/src/*"],
      "@ventostack/integration": ["./packages/integration/src/index.ts"],
      "@ventostack/integration/*": ["./packages/integration/src/*"],
      "@ventostack/system": ["./packages/platform/system/src/index.ts"],
      "@ventostack/system/*": ["./packages/platform/system/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts", "apps/docs"]
}
